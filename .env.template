# ============================
# CONFIGURAÇÃO DO SITE
# ============================
# Copie este arquivo para .env e preencha os valores

# ============================
# INFORMAÇÕES DA EMPRESA
# ============================
NOME_EMPRESA=NomeEmpresa
TAGLINE_EMPRESA=Construção Civil
EMAIL_CONTATO=contato@nomeempresa.com.br
TELEFONE_1=(11) 3000-0000
TELEFONE_2=(11) 99999-9999
ENDERECO=Rua das Construções, 1000 - São Paulo, SP

# ============================
# INTEGRAÇÃO COM FORMULÁRIO
# ============================

# Opção 1: Formspree (Recomendado - Gratuito)
# 1. Acesse https://formspree.io
# 2. Crie conta e projeto
# 3. Copie o ID do projeto abaixo
FORMSPREE_ID=sua_id_aqui

# Opção 2: Backend Customizado (Se tiver servidor)
# Deixe vazio se não usar
BACKEND_URL=

# Opção 3: EmailJS (Alternativo)
# EMAILJS_SERVICE_ID=seu_service_id
# EMAILJS_TEMPLATE_ID=seu_template_id
# EMAILJS_PUBLIC_KEY=sua_chave_publica

# ============================
# SEO E METATAGS
# ============================

# URL canônica do site
SITE_URL=https://seu-dominio.com.br

# Descrição do site
SITE_DESCRIPTION=NomeEmpresa oferece serviços de construção civil, reformas, projetos e manutenção com qualidade garantida.

# Palavras-chave
SITE_KEYWORDS=construção civil, reforma, projetos, São Paulo

# Imagem para redes sociais (URL completa)
SITE_IMAGE=https://seu-dominio.com.br/images/og-image.jpg

# ============================
# ANÁLITICS E RASTREAMENTO
# ============================

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Google Search Console (Verificação)
GOOGLE_SITE_VERIFICATION=

# ============================
# REDES SOCIAIS
# ============================

FACEBOOK_URL=https://facebook.com/nomeempresa
INSTAGRAM_URL=https://instagram.com/nomeempresa
LINKEDIN_URL=https://linkedin.com/company/nomeempresa
WHATSAPP_NUMERO=5511999999999

# ============================
# AMBIENTE
# ============================

# development, staging ou production
NODE_ENV=production

# Debug (true/false)
DEBUG=false
